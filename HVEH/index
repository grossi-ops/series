// Cross-repo edges — connections between repos
const CROSS_EDGES = [
  ['geometry','AXLE'],           // HTML chapters cite Lean proofs
  ['geometry','3M'],             // Ocio/Monster Law chapters
  ['geometry','Collatz'],        // Collatz chapter
  ['AXLE','DM3-lab'],            // AXLE formalizes DM3 numerics
  ['AXLE','GTCT'],               // AXLE verifies GTCT
  ['AXLE','3M'],                 // Monster Law in Lean
  ['DM3-lab','GTCT'],            // numerics instantiate GTCT
  ['3M','GTCT'],                 // Monster Law is GTCT layer
  ['cajueiro','geometry'],       // cajueiro principle in ch1
  ['helical-contact','GTCT'],    // helical contact = GTCT
  ['TO','GTCT'],                 // TO/TOGT = GTCT core
  ['TO','AXLE'],                 // TO verified in AXLE
  ['PrincipioOrtogonal','geometry'], // PT version
  ['g6-B3','geometry'],          // B3 = geometry chapters
  ['g6-B3','AXLE'],              // B3 formal layer
  ['mini-beast','geometry'],     // same book different org
  ['Collatz','AXLE'],            // Collatz AXLE Target 5
  ['Atratores','DM3-lab'],       // attractors in numerics
  ['grossi-Atratores','Atratores'],
  ['maths','AXLE'],
  ['book3-starter','geometry'],
];

const cv = document.getElementById('cv');
const ctx = cv.getContext('2d');
let W, H, rotX=0.25, rotY=0.4, drag=false, lx, ly, zoom=0.9, hov=null, spinning=true, raf=null, lastAct=Date.now();

// Build flat node list with 3D positions around repo centers
let allNodes = [];
function buildNodes(){
  allNodes = [];
  REPOS.forEach(repo=>{
    // Repo hub node
    allNodes.push({
      ...repo,
      isHub:true,
      ox:repo.ox, oy:repo.oy, oz:repo.oz,
      r:22, col:repo.color, scol:repo.stroke,
      label:repo.label, desc:repo.desc, url:repo.live||repo.url,
      repoId:repo.id
    });
    // Chapter nodes around hub
    if(repo.nodes){
      repo.nodes.forEach((n,i)=>{
        const a=(i/repo.nodes.length)*Math.PI*2;
        const rd=48;
        allNodes.push({
          ...n,
          isHub:false,
          ox:repo.ox+Math.cos(a)*rd,
          oy:repo.oy+Math.sin(a)*rd*0.6-10,
          oz:repo.oz+Math.sin(a)*rd,
          r:10, col:repo.color+'aa', scol:repo.stroke,
          desc:n.label+' · '+repo.label,
          repoId:repo.id,
          repoColor:repo.color,
        });
      });
    }
  });
}

function proj(ox,oy,oz){
  const cX=Math.cos(rotX),sX=Math.sin(rotX);
  const cY=Math.cos(rotY),sY=Math.sin(rotY);
  const x1=ox*cY+oz*sY, z1=-ox*sY+oz*cY;
  const y1=oy*cX-z1*sX, z2=oy*sX+z1*cX;
  const f=500*zoom/(500*zoom+z2+400);
  return {sx:W/2+x1*f, sy:H/2+y1*f, sc:f, z:z2};
}

function resize(){
  W=cv.width=window.innerWidth*devicePixelRatio;
  H=cv.height=window.innerHeight*devicePixelRatio;
  ctx.scale(devicePixelRatio,devicePixelRatio);
  draw();
}

function draw(){
  const rW=W/devicePixelRatio, rH=H/devicePixelRatio;
  ctx.clearRect(0,0,W,H);

  // Stars
  ctx.fillStyle='#03000a';
  ctx.fillRect(0,0,rW,rH);
  ctx.fillStyle='rgba(255,255,255,0.35)';
  [[0.08,0.12],[0.92,0.08],[0.45,0.05],[0.78,0.22],[0.15,0.65],[0.88,0.55],
   [0.33,0.88],[0.62,0.78],[0.05,0.42],[0.72,0.42],[0.28,0.35],[0.55,0.18]].forEach(([x,y])=>{
    ctx.beginPath();ctx.arc(x*rW,y*rH,0.8,0,Math.PI*2);ctx.fill();
  });

  const ps = allNodes.map(n=>({...n,...proj(n.ox,n.oy,n.oz)})).sort((a,b)=>a.z-b.z);

  // Cross-repo edges
  CROSS_EDGES.forEach(([a,b])=>{
    const na=ps.find(n=>n.isHub&&n.id===a);
    const nb=ps.find(n=>n.isHub&&n.id===b);
    if(!na||!nb)return;
    ctx.beginPath();ctx.moveTo(na.sx,na.sy);ctx.lineTo(nb.sx,nb.sy);
    ctx.strokeStyle='rgba(201,168,76,0.08)';ctx.lineWidth=0.8;ctx.stroke();
  });

  // Intra-repo edges (hub to children)
  REPOS.forEach(repo=>{
    const hub=ps.find(n=>n.isHub&&n.id===repo.id);
    if(!hub)return;
    const children=ps.filter(n=>!n.isHub&&n.repoId===repo.id);
    children.forEach(ch=>{
      ctx.beginPath();ctx.moveTo(hub.sx,hub.sy);ctx.lineTo(ch.sx,ch.sy);
      ctx.strokeStyle=repo.color+'30';ctx.lineWidth=0.5;ctx.stroke();
    });
  });

  // Nodes
  for(const n of ps){
    const isH=hov&&hov.id===n.id&&hov.repoId===n.repoId;
    const r=n.r*n.sc*(n.isHub?2.2:1.6);

    if(isH){
      ctx.beginPath();ctx.arc(n.sx,n.sy,r*2.2,0,Math.PI*2);
      ctx.fillStyle='rgba(201,168,76,0.08)';ctx.fill();
    }

    // Glow for hubs
    if(n.isHub){
      ctx.beginPath();ctx.arc(n.sx,n.sy,r*1.5,0,Math.PI*2);
      const grd=ctx.createRadialGradient(n.sx,n.sy,0,n.sx,n.sy,r*1.5);
      grd.addColorStop(0,n.col+'40');grd.addColorStop(1,'transparent');
      ctx.fillStyle=grd;ctx.fill();
    }

    ctx.beginPath();ctx.arc(n.sx,n.sy,r,0,Math.PI*2);
    ctx.fillStyle=n.col+(n.isHub?'ee':'99');ctx.fill();
    ctx.strokeStyle=n.scol;ctx.lineWidth=isH?1.5:0.5;ctx.stroke();

    // Label
    if(r>8){
      ctx.fillStyle='#fff';
      ctx.font=`${Math.max(7,Math.round(r*(n.isHub?0.55:0.65)))}px "Courier New",monospace`;
      ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(n.isHub?n.short:n.s,n.sx,n.sy);
    }
  }

  // Hub labels below
  ps.filter(n=>n.isHub).forEach(n=>{
    const r=n.r*n.sc*2.2;
    ctx.font=`${Math.max(8,Math.round(r*0.45))}px "Courier New",monospace`;
    ctx.textAlign='center';ctx.textBaseline='top';
    ctx.fillStyle=n.col+'88';
    ctx.fillText(n.short,n.sx,n.sy+r+3);
  });
}

function getHov(mx,my){
  let best=null,bd=Infinity;
  allNodes.forEach(n=>{
    const p=proj(n.ox,n.oy,n.oz);
    const r=(n.r+(n.isHub?8:4))*p.sc*(n.isHub?2.2:1.6);
    const d=Math.hypot(mx-p.sx,my-p.sy);
    if(d<r&&d<bd){bd=d;best=n;}
  });
  return best;
}

function setInfo(n){
  const hint=document.getElementById('hint');
  if(!n){
    document.getElementById('info-repo').textContent='';
    document.getElementById('info-title').textContent='Principia Orthogona · Complete Opus';
    document.getElementById('info-desc').textContent='Drag to rotate · scroll to zoom · hover a node to preview · click to open repository';
    document.getElementById('info-link').innerHTML='';
    hint.style.display='block';
  } else {
    hint.style.display='none';
    const repo=REPOS.find(r=>r.id===n.repoId);
    document.getElementById('info-repo').textContent=(repo?repo.id:n.repoId)+' · GitHub';
    document.getElementById('info-title').textContent=n.label||n.id;
    document.getElementById('info-desc').textContent=n.desc||'';
    document.getElementById('info-link').innerHTML=
      `<a href="${n.url||n.live}" target="_blank">Open → ${(n.url||'').replace('https://','')}</a>`;
  }
}

window.resetView=()=>{rotX=0.25;rotY=0.4;zoom=0.9;draw();};
let spinOn=true;
window.toggleSpin=()=>{
  spinOn=!spinOn;
  document.getElementById('spin-btn').style.color=spinOn?'#c9a84c':'rgba(201,168,76,0.3)';
};

cv.addEventListener('mousedown',e=>{drag=true;lx=e.clientX;ly=e.clientY;lastAct=Date.now();});
cv.addEventListener('touchstart',e=>{drag=true;lx=e.touches[0].clientX;ly=e.touches[0].clientY;lastAct=Date.now();},{passive:true});
window.addEventListener('mouseup',()=>drag=false);
window.addEventListener('touchend',()=>drag=false);
cv.addEventListener('mousemove',e=>{
  if(drag){
    rotY+=(e.clientX-lx)*0.007;rotX+=(e.clientY-ly)*0.005;
    rotX=Math.max(-1.4,Math.min(1.4,rotX));
    lx=e.clientX;ly=e.clientY;lastAct=Date.now();draw();
  } else {
    const h=getHov(e.clientX,e.clientY);
    if(!h||h.id!==hov?.id||h.repoId!==hov?.repoId){hov=h;setInfo(h);draw();}
    cv.style.cursor=h?'pointer':'crosshair';
  }
});
cv.addEventListener('touchmove',e=>{
  if(!drag)return;
  rotY+=(e.touches[0].clientX-lx)*0.007;rotX+=(e.touches[0].clientY-ly)*0.005;
  rotX=Math.max(-1.4,Math.min(1.4,rotX));lx=e.touches[0].clientX;ly=e.touches[0].clientY;lastAct=Date.now();draw();
},{passive:true});
cv.addEventListener('click',e=>{
  const n=getHov(e.clientX,e.clientY);
  if(n&&(n.url||n.live))window.open(n.url||n.live,'_blank');
});
cv.addEventListener('wheel',e=>{
  e.preventDefault();zoom=Math.max(0.3,Math.min(3,zoom*(e.deltaY>0?0.92:1.09)));
  lastAct=Date.now();draw();
},{passive:false});

function loop(){
  if(spinOn&&!drag&&Date.now()-lastAct>2000){rotY+=0.003;draw();}
  requestAnimationFrame(loop);
}

window.addEventListener('resize',resize);
buildNodes();
resize();
setInfo(null);
loop();
</script>
