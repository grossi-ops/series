<script>
// Subtle animated background — turtle shell hex tiles
(function(){
  const c=document.getElementById('bgCanvas');
  if(!c)return;
  const ctx=c.getContext('2d');
  function resize(){
    c.width=c.offsetWidth; c.height=c.offsetHeight;
  }
  resize(); window.addEventListener('resize',resize);
  let t=0;
  function draw(){
    const W=c.offsetWidth,H=c.offsetHeight;
    ctx.clearRect(0,0,W,H);
    const sw=48,sh=30;
    for(let row=-1;row<Math.ceil(H/sh)+2;row++){
      for(let col=-1;col<Math.ceil(W/sw)+2;col++){
        const ox=(row%2)*sw*0.5;
        const x=col*sw+ox,y=row*sh;
        const dist=Math.sqrt((x-W/2)**2+(y-H/2)**2);
        const pulse=Math.sin(dist*0.01-t*0.3)*0.5+0.5;
        ctx.strokeStyle=`rgba(201,168,76,${0.02+pulse*0.04})`;
        ctx.lineWidth=0.6;
        ctx.beginPath();
        ctx.moveTo(x+sw*0.5,y);
        ctx.lineTo(x+sw,y+sh*0.4);
        ctx.lineTo(x+sw,y+sh*0.9);
        ctx.lineTo(x+sw*0.5,y+sh);
        ctx.lineTo(x,y+sh*0.9);
        ctx.lineTo(x,y+sh*0.4);
        ctx.closePath();
        ctx.stroke();
      }
    }
    t+=0.008;
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>
